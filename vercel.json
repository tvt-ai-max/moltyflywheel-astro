{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "moltyflywheel.com"
        }
      ],
      "destination": "https://www.moltyflywheel.com/:path*",
      "statusCode": 301
    }
  ]
}
