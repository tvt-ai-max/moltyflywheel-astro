---
// BlogSidebar.astro — Left sticky sidebar: author card + share + related posts widget
interface Props {
  pubDate: Date;
  title: string;
  relatedPosts?: { slug: string; title: string }[];
}
const { pubDate, title, relatedPosts = [] } = Astro.props;

const dateStr = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const pageUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);
---

<aside class="hidden lg:flex flex-col gap-4 w-[180px] shrink-0">
  <div class="sticky top-24 flex flex-col gap-4">

    <!-- Author Card -->
    <div class="bg-[#0B3B59] rounded-2xl p-4 border border-[#1a4560]">
      <div class="flex flex-col items-center text-center gap-2.5">
        <div class="relative">
          <div class="w-14 h-14 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-lg"
            style="background: linear-gradient(135deg, #72DBF2, #2173A6);">
            MF
          </div>
          <span class="absolute bottom-0 right-0 w-4 h-4 bg-emerald-500 rounded-full border-2 border-[#0B3B59]"></span>
        </div>
        <div>
          <p class="font-semibold text-[#daeef5] text-sm">MoltyFlywheel</p>
          <p class="text-[11px] text-[#3d7a96] mt-0.5">AI Affiliate Expert</p>
        </div>
      </div>

      <!-- Meta -->
      <div class="mt-3 pt-3 border-t border-[#1a4560] space-y-1.5">
        <div class="flex items-center gap-2 text-[11px] text-[#3d7a96]">
          <svg class="w-3.5 h-3.5 text-[#72DBF2] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <time>{dateStr}</time>
        </div>
        <div class="flex items-center gap-2 text-[11px] text-[#3d7a96]">
          <svg class="w-3.5 h-3.5 text-[#72DBF2] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span id="sidebar-read-time">— min read</span>
        </div>
      </div>
    </div>

    <!-- Social Share -->
    <div class="bg-[#0B3B59] rounded-2xl p-4 border border-[#1a4560]">
      <p class="text-[10px] font-bold text-[#3d7a96] uppercase tracking-widest mb-3 text-center">Share</p>
      <div class="flex flex-col gap-1.5">

        <!-- X / Twitter -->
        <a href={`https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
          target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-2.5 bg-[#011826] hover:bg-[#0d2d40] text-[#5ea4bf] hover:text-white rounded-lg px-3 py-2 text-[11px] font-medium transition-all">
          <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          X / Twitter
        </a>

        <!-- LinkedIn -->
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
          target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-2.5 bg-[#011826] hover:bg-blue-950 text-[#5ea4bf] hover:text-blue-400 rounded-lg px-3 py-2 text-[11px] font-medium transition-all">
          <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>

        <!-- Copy Link -->
        <button id="sidebar-copy-btn"
          class="flex items-center gap-2.5 bg-[#011826] hover:bg-[#0d2d40] text-[#5ea4bf] hover:text-[#72DBF2] rounded-lg px-3 py-2 text-[11px] font-medium transition-all w-full text-left">
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
          <span id="sidebar-copy-label">Copy Link</span>
        </button>
      </div>
    </div>

    <!-- Related Posts (if provided) -->
    {relatedPosts.length > 0 && (
      <div class="bg-[#0B3B59] rounded-2xl p-4 border border-[#1a4560]">
        <p class="text-[10px] font-bold text-[#3d7a96] uppercase tracking-widest mb-3">Related</p>
        <div class="flex flex-col gap-3">
          {relatedPosts.map(p => (
            <a href={`/blog/${p.slug}`} class="group flex flex-col gap-0.5">
              <span class="text-[11px] text-[#89c0d4] group-hover:text-[#72DBF2] transition-colors leading-snug font-medium">
                {p.title}
              </span>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</aside>

<script>
  // Copy link
  const copyBtn = document.getElementById('sidebar-copy-btn');
  const copyLabel = document.getElementById('sidebar-copy-label');
  if (copyBtn && copyLabel) {
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        copyLabel.textContent = '✓ Copied!';
        setTimeout(() => { copyLabel.textContent = 'Copy Link'; }, 2200);
      });
    });
  }

  // Estimated read time
  function calcReadTime() {
    const article = document.getElementById('article-body');
    if (!article) return;
    const words = article.innerText.trim().split(/\s+/).length;
    const mins = Math.max(1, Math.round(words / 220));
    const el = document.getElementById('sidebar-read-time');
    if (el) el.textContent = mins + ' min read';
  }
  document.addEventListener('DOMContentLoaded', calcReadTime);
</script>
