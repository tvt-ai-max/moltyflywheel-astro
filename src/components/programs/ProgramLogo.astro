---
interface Props {
  name: string;
  logo?: string;
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { name, logo, class: className = '', size = 'md' } = Astro.props;

const initials = name
  .split(/[\s.-]+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0]?.toUpperCase() ?? '')
  .join('')
  .slice(0, 2);

const sizeClasses = {
  sm: 'h-14 w-14 rounded-2xl',
  md: 'h-18 w-18 rounded-[22px]',
  lg: 'h-24 w-24 rounded-[26px]',
} as const;
---

<div class:list={['relative overflow-hidden border border-[#1a4560] bg-[linear-gradient(160deg,rgba(11,59,89,0.96),rgba(1,24,38,0.92))] shadow-[0_10px_28px_rgba(1,24,38,0.25)]', sizeClasses[size], className]}>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_18%,rgba(114,219,242,0.16),transparent_30%),radial-gradient(circle_at_78%_82%,rgba(33,115,166,0.18),transparent_36%)]"></div>
  <div class="absolute inset-0 opacity-[0.06]" style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.35) 0px, rgba(255,255,255,0.35) 1px, transparent 1px, transparent 12px);"></div>

  {logo ? (
    <img
      src={logo}
      alt={`${name} logo`}
      loading="lazy"
      decoding="async"
      class="absolute inset-0 h-full w-full object-contain p-3"
    />
  ) : (
    <div class="absolute inset-0 flex items-center justify-center">
      <span class="text-xl font-black tracking-[-0.06em] text-[#daeef5]">{initials}</span>
    </div>
  )}
</div>
