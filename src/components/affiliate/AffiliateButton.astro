---
interface Props {
  program: string;
  label?: string;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'primary' | 'outline';
}
const { program, label = 'Get Started →', size = 'md', variant = 'primary' } = Astro.props;

// Internal redirect path — managed via public/_redirects
// Cloudflare Pages routes /go/[program] → real affiliate URL
const href = `/go/${program}`;
---
<a
  href={href}
  class:list={[
    'inline-flex items-center font-semibold rounded-lg transition-all duration-200',
    size === 'lg' && 'px-8 py-4 text-lg',
    size === 'md' && 'px-6 py-3 text-base',
    size === 'sm' && 'px-4 py-2 text-sm',
    variant === 'primary' && 'bg-[#2173A6] hover:bg-[#1a5d8c] text-white shadow-lg hover:shadow-xl hover:-translate-y-0.5',
    variant === 'outline' && 'border-2 border-[#72DBF2] text-[#72DBF2] hover:bg-[#72DBF2]/10',
  ]}
  rel="nofollow sponsored"
  target="_blank"
>
  {label}
</a>
