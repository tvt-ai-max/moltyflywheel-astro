---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact Us" description="Get in touch with the MoltyFlywheel team.">
  <div class="max-w-3xl mx-auto px-6 py-16 text-center">
    <h1 class="text-4xl font-black mb-8">Contact Us</h1>
    <p class="text-xl text-gray-400 mb-12">
      Have questions about the AI Flywheel or OpenClaw? We'd love to hear from you.
    </p>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 max-w-md mx-auto">
      <div class="mb-8">
        <h3 class="text-gray-500 uppercase text-xs font-bold tracking-widest mb-2">Email</h3>
        <p class="text-2xl font-bold text-amber-500">hello@moltyflywheel.com</p>
      </div>
      <div>
        <h3 class="text-gray-500 uppercase text-xs font-bold tracking-widest mb-2">X (Twitter)</h3>
        <p class="text-2xl font-bold text-amber-500">@moltyflywheel</p>
      </div>
    </div>
  </div>
</BaseLayout>
