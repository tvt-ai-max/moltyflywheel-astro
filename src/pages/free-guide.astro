---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Free AI Affiliate Guide" description="Download the complete AI Affiliate Flywheel blueprint for free.">
  <div class="max-w-4xl mx-auto px-6 py-24 text-center">
    <h1 class="text-4xl md:text-6xl font-black mb-6">The 2026 AI Affiliate<br/><span class="text-amber-500">Master Blueprint</span></h1>
    <p class="text-xl text-gray-400 mb-12 max-w-2xl mx-auto">
      How we built a $3,000/mo passive income stream using Claude Pro and the OpenClaw automation engine.
    </p>
    
    <div class="bg-gray-900 border border-gray-800 rounded-3xl p-8 md:p-12 max-w-lg mx-auto shadow-2xl">
      <h3 class="text-2xl font-bold mb-6">Get the Free Guide</h3>
      <form class="space-y-4">
        <input type="email" placeholder="Your best email address..." class="w-full bg-gray-800 border border-gray-700 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-amber-500 transition-colors" required />
        <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-4 rounded-xl shadow-lg transition-all hover:-translate-y-0.5">
          Send Me the PDF →
        </button>
      </form>
      <p class="text-xs text-gray-500 mt-6">
        Join 2,400+ marketers. No spam. Unsubscribe anytime.
      </p>
    </div>
  </div>
</BaseLayout>
