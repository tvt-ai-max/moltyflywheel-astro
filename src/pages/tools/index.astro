---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProgramLogo from '../../components/programs/ProgramLogo.astro';
import { getCollection } from 'astro:content';
import skillsData from '../../data/skills.json';
import migrationMap from '../../data/tools/migration-map-v1.json';

const programs = await getCollection('programs', ({ data }) => !data.draft);

const categoryMeta = {
  'research-discovery': {
    label: 'Research',
    shortLabel: 'Research',
    description: 'Discover niches, programs, and competitive openings before you build.',
  },
  'planning-governance': {
    label: 'Planning',
    shortLabel: 'Planning',
    description: 'Design the system, define the rules, and keep the operating layer clean.',
  },
  'content-production': {
    label: 'Content',
    shortLabel: 'Content',
    description: 'Create editorial assets, comparisons, tutorials, and reusable content outputs.',
  },
  'conversion-assets': {
    label: 'Conversion',
    shortLabel: 'Conversion',
    description: 'Build landing pages, offers, and other assets that turn attention into action.',
  },
  'distribution-activation': {
    label: 'Distribution',
    shortLabel: 'Distribution',
    description: 'Publish, distribute, and activate email or channel workflows.',
  },
  'measurement-optimization': {
    label: 'Measurement',
    shortLabel: 'Measurement',
    description: 'Audit, score, test, and improve what is already live.',
  },
  'platform-operations': {
    label: 'Operations',
    shortLabel: 'Operations',
    description: 'Monitor runtime health, alerts, cost control, and operator-level maintenance.',
  },
} as const;

const toolCategoryToJobFamily = {
  'ai-writing': 'content-production',
  seo: 'measurement-optimization',
  email: 'distribution-activation',
  'general-ai': 'research-discovery',
  productivity: 'platform-operations',
} as const;

const migrationById = new Map(
  migrationMap.records.map((record) => [record.legacy_id, record]),
);

const skills = skillsData
  .map((skill) => {
    const mapped = migrationById.get(skill.id);

    return {
      id: skill.id,
      slug: skill.id,
      kind: 'skill' as const,
      name: skill.name,
      description: skill.description,
      tier: skill.tier,
      cost: skill.cost,
      legacyCategory: skill.category,
      entityType: mapped?.entity_type ?? 'internal-skill',
      primaryCategory: mapped?.primary_category ?? 'planning-governance',
      secondaryCategory: mapped?.secondary_category ?? '',
      tags: mapped?.suggested_tags ?? [],
      manualReview: mapped?.manual_review ?? false,
      cleanupNeeded: mapped?.cleanup_needed ?? false,
    };
  })
  .sort((a, b) => a.name.localeCompare(b.name));

const tools = programs
  .map((entry) => ({
    kind: 'tool' as const,
    slug: entry.slug,
    name: entry.data.name,
    description: entry.data.description,
    logo: entry.data.logo,
    category: entry.data.category,
    rating: entry.data.rating,
    commission: entry.data.commission,
    href: `/programs/${entry.slug}/`,
    jobFamily: toolCategoryToJobFamily[entry.data.category],
    featured: entry.data.featured,
    destinationType: 'program-review' as const,
    categoryLabel: entry.data.category.replace('-', ' '),
    metaBadges: [entry.data.commission.type.toUpperCase(), entry.data.commission.cookieDuration],
    footerMeta: `${entry.data.rating.toFixed(1)} / 5 editorial score`,
  }))
  .sort((a, b) => b.rating - a.rating || a.name.localeCompare(b.name));

const externalTools = [
  {
    kind: 'tool' as const,
    slug: 'abacus-ai',
    name: 'Abacus AI',
    description:
      'An all-in-one AI workspace centered on ChatLLM Teams, Deep Agent, and Abacus Claw for teams that want top models plus a hosted OpenClaw-style path.',
    logo: '',
    category: 'general-ai',
    rating: 4.7,
    commission: null,
    href: '/tools/abacus-ai/',
    jobFamily: 'platform-operations',
    featured: true,
    destinationType: 'tool-detail' as const,
    categoryLabel: 'agent platform',
    metaBadges: ['External tool', 'Models + agents'],
    footerMeta: 'Best fit for all-in-one AI operations and hosted agents',
    tags: ['chatllm', 'deep-agent', 'abacus-claw', 'openclaw-alternative'],
  },
  {
    kind: 'tool' as const,
    slug: 'kyma-api',
    name: 'Kyma API',
    description:
      'An OpenAI-compatible model gateway built around one API key, curated active models, 4-layer auto-failover, prompt caching, and direct OpenClaw compatibility.',
    logo: '',
    category: 'general-ai',
    rating: 4.7,
    commission: null,
    href: '/tools/kyma-api/',
    jobFamily: 'platform-operations',
    featured: true,
    destinationType: 'tool-detail' as const,
    categoryLabel: 'api gateway',
    metaBadges: ['External tool', 'Models + routing'],
    footerMeta: 'Best fit for model routing, agent reliability, and lower-friction API ops',
    tags: ['openai-compatible', 'openclaw', 'api-gateway', 'prompt-caching'],
  },
  {
    kind: 'tool' as const,
    slug: 'topview-ai',
    name: 'Topview AI',
    description:
      'An AI video agent built around UGC-style marketing videos, product-led ads, reference-based video recreation, and faster ad creative workflows.',
    logo: '',
    category: 'general-ai',
    rating: 4.6,
    commission: null,
    href: '/tools/topview-ai/',
    jobFamily: 'content-production',
    featured: true,
    destinationType: 'tool-detail' as const,
    categoryLabel: 'video ads',
    metaBadges: ['External tool', 'AI video agent'],
    footerMeta: 'Best fit for ad creatives, UGC-style content, and product videos',
    tags: ['ugc-video', 'ai-ads', 'product-video', 'affiliate-marketing'],
  },
  {
    kind: 'tool' as const,
    slug: 'higgsfield',
    name: 'Higgsfield',
    description:
      'A creator-focused AI video and image platform built around cinematic controls, camera logic, and faster visual production workflows.',
    logo: '',
    category: 'general-ai',
    rating: 4.6,
    commission: null,
    href: '/tools/higgsfield/',
    jobFamily: 'content-production',
    featured: true,
    destinationType: 'tool-detail' as const,
    categoryLabel: 'creator video',
    metaBadges: ['External tool', 'Video & image AI'],
    footerMeta: 'Best fit for creator-side visual workflows',
    tags: ['video-generation', 'image-generation', 'creator-tools'],
  },
];

const toolsWithExternal = [...tools, ...externalTools].sort(
  (a, b) => b.rating - a.rating || a.name.localeCompare(b.name),
);

const featuredSkillIds = [
  'affiliate-blog-builder',
  'affiliate-program-search',
  'landing-page-creator',
  'content-decay-detector',
  'email-automation-builder',
  'openclaw-health-check',
];

const featuredSkills = featuredSkillIds
  .map((id) => skills.find((skill) => skill.id === id))
  .filter(Boolean);

const featuredTools = toolsWithExternal.filter((tool) => tool.featured).slice(0, 6);

const workflowCollections = [
  {
    title: 'Start a content workflow',
    description: 'Move from keyword planning into long-form production and repurposing.',
    skills: ['keyword-cluster-architect', 'affiliate-blog-builder', 'content-pillar-atomizer'],
    tools: ['koala-writer', 'writesonic'],
  },
  {
    title: 'Build an affiliate review workflow',
    description: 'Research programs, write comparison content, and sharpen recommendation logic.',
    skills: ['affiliate-program-search', 'comparison-post-writer', 'bonus-stack-builder'],
    tools: ['surfer-seo', 'copy-ai'],
  },
  {
    title: 'Launch a landing page faster',
    description: 'Go from offer design into page creation and deployment without rebuilding the system every time.',
    skills: ['grand-slam-offer', 'landing-page-creator', 'github-pages-deployer'],
    tools: ['webflow', 'framer'],
  },
  {
    title: 'Repurpose content across channels',
    description: 'Turn one core asset into social, video, and email distribution layers.',
    skills: ['content-repurposer', 'twitter-thread-writer', 'email-drip-sequence'],
    tools: ['beehiiv', 'topview-ai'],
  },
  {
    title: 'Measure and optimize performance',
    description: 'Track what is working, detect decay, and improve the live system intentionally.',
    skills: ['conversion-tracker', 'content-decay-detector', 'performance-report'],
    tools: ['semrush', 'kyma-api'],
  },
];

const beginnerPaths = [
  {
    title: "I'm new to AI tools",
    description: 'Start with low-friction platforms and a few workflow primitives before expanding the stack.',
    href: '/programs/',
    cta: 'Browse beginner-friendly tools',
  },
  {
    title: 'I want to create content faster',
    description: 'Go straight into writing, repurposing, and optimization workflows that shorten production time.',
    href: '#featured-skills',
    cta: 'Start with skills',
  },
  {
    title: 'I want to build an affiliate workflow',
    description: 'Use the library to discover programs, compare fit, then move into offer and content execution.',
    href: '/offers/',
    cta: 'See offer paths',
  },
];

const faqItems = [
  {
    question: 'What is the difference between a tool and a skill?',
    answer:
      'Tools are products or platforms people use directly. Skills are reusable operating modules that explain how the work gets done across research, content, conversion, distribution, and optimization.',
  },
  {
    question: 'Who is this library for?',
    answer:
      'Creators, affiliate operators, and systems-minded builders who want a clearer operating view of what to use and what to do next.',
  },
  {
    question: 'Where should beginners start?',
    answer:
      'Start with the split between Tools and Skills, then use the beginner paths section to choose a first route into programs, content workflows, or offers.',
  },
  {
    question: 'How does this connect to Programs, Blog, and Offers?',
    answer:
      'Programs show product and affiliate-entry detail, Blog explains the decision layer through reviews and comparisons, and Offers package the recommendation layer for action.',
  },
];

const libraryItems = [
  ...toolsWithExternal.map((tool) => ({
    id: `tool-${tool.slug}`,
    kind: tool.kind,
    name: tool.name,
    description: tool.description,
    href: tool.href,
    label: tool.categoryLabel,
    filterCategory: tool.jobFamily,
    tags: tool.tags ?? [
      tool.category,
      ...(tool.commission ? [tool.commission.type] : []),
      `${tool.rating.toFixed(1)}-rating`,
    ],
    tool,
  })),
  ...skills.map((skill) => ({
    id: `skill-${skill.slug}`,
    kind: skill.kind,
    name: skill.name,
    description: skill.description,
    href: `#job-family-${skill.primaryCategory}`,
    label: categoryMeta[skill.primaryCategory].shortLabel,
    filterCategory: skill.primaryCategory,
    tags: skill.tags,
    skill,
  })),
];

const libraryCounts = {
  all: libraryItems.length,
  tools: toolsWithExternal.length,
  skills: skills.length,
};

const groupedSkills = Object.entries(categoryMeta)
  .map(([key, meta]) => ({
    key,
    meta,
    items: skills.filter((skill) => skill.primaryCategory === key),
  }))
  .filter((group) => group.items.length > 0);
---

<BaseLayout title="Tools & Skills Operating Library | MoltyFlywheel" description="Explore the operating library behind MoltyFlywheel: tools people use directly, skills that explain how the work gets done, and workflow paths that connect discovery to execution.">
  <main class="bg-[#011826] text-[#daeef5]">
    <section class="relative overflow-hidden border-b border-[#0d2d40]">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(114,219,242,0.14),transparent_34%),linear-gradient(180deg,rgba(11,59,89,0.28),transparent)]"></div>
      <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(rgba(255,255,255,0.18) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.18) 1px, transparent 1px); background-size: 80px 80px;"></div>
      <div class="relative mx-auto max-w-7xl px-6 py-18 sm:px-8 lg:px-10 lg:py-24">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1.25fr)_minmax(320px,420px)] lg:items-end">
          <div class="max-w-3xl">
            <span class="inline-flex items-center gap-2 rounded-full border border-[#1a4560] bg-[#0B3B59]/65 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.28em] text-[#72DBF2]">
              Tools & Skills Library
            </span>
            <h1 class="mt-6 max-w-4xl text-4xl font-black tracking-[-0.05em] text-[#f4fbff] sm:text-5xl lg:text-6xl">
              The operating library behind better AI workflow decisions.
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-[#9dc6d8]">
              Explore the products people use directly, the skills that explain how the work gets done, and the workflow paths that connect research, content, conversion, and optimization.
            </p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="#library" class="inline-flex items-center justify-center rounded-2xl bg-[#2173A6] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#2f8bc4]">
                Explore the library
              </a>
              <a href="#split-entry" class="inline-flex items-center justify-center rounded-2xl border border-[#1a4560] px-6 py-3 text-sm font-semibold text-[#b6d9e7] transition hover:border-[#72DBF2] hover:text-[#f4fbff]">
                See tools vs skills
              </a>
            </div>
            <div class="mt-8 flex flex-wrap gap-3 text-sm text-[#89b8cb]">
              <span class="rounded-full border border-[#14384f] bg-[#0B3B59]/35 px-3 py-2">{toolsWithExternal.length} tools</span>
              <span class="rounded-full border border-[#14384f] bg-[#0B3B59]/35 px-3 py-2">{skills.length} skills</span>
              <span class="rounded-full border border-[#14384f] bg-[#0B3B59]/35 px-3 py-2">7 job families</span>
            </div>
          </div>

          <div class="rounded-[32px] border border-[#1a4560] bg-[linear-gradient(160deg,rgba(11,59,89,0.9),rgba(1,24,38,0.88))] p-6 shadow-[0_22px_60px_rgba(0,0,0,0.28)]">
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="rounded-3xl border border-[#1a4560] bg-[#082b40]/75 p-5">
                <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#72DBF2]">Tools</p>
                <p class="mt-3 text-2xl font-black tracking-[-0.04em] text-[#f4fbff]">{toolsWithExternal.length}</p>
                <p class="mt-2 text-sm leading-6 text-[#8fb7c9]">Apps, platforms, and products people use directly.</p>
              </div>
              <div class="rounded-3xl border border-[#1a4560] bg-[#082b40]/75 p-5">
                <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#72DBF2]">Skills</p>
                <p class="mt-3 text-2xl font-black tracking-[-0.04em] text-[#f4fbff]">{skills.length}</p>
                <p class="mt-2 text-sm leading-6 text-[#8fb7c9]">Reusable workflow modules and operator playbooks.</p>
              </div>
            </div>
            <div class="mt-4 rounded-3xl border border-[#1a4560] bg-[#082b40]/55 p-5">
              <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#72DBF2]">What this page is for</p>
              <p class="mt-3 text-sm leading-7 text-[#b8d9e6]">
                Use this library when you need clarity before action: what to use, what capability matters, and which route in the MoltyFlywheel ecosystem should come next.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="split-entry" class="border-b border-[#0d2d40] bg-[#041f31]">
      <div class="mx-auto max-w-7xl px-6 py-16 sm:px-8 lg:px-10">
        <div class="max-w-2xl">
          <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#72DBF2]">Start Here</p>
          <h2 class="mt-4 text-3xl font-black tracking-[-0.04em] text-[#f4fbff] sm:text-4xl">Two entry points. Two different jobs.</h2>
        </div>
        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          <article class="rounded-[32px] border border-[#1a4560] bg-[linear-gradient(180deg,rgba(11,59,89,0.82),rgba(1,24,38,0.92))] p-7 shadow-[0_20px_50px_rgba(0,0,0,0.2)]">
            <div class="flex items-center justify-between gap-4">
              <span class="rounded-full border border-[#1f5f82] bg-[#2173A6]/15 px-3 py-2 text-[11px] font-semibold uppercase tracking-[0.24em] text-[#72DBF2]">Tools</span>
              <span class="text-sm text-[#89b8cb]">{toolsWithExternal.length} entries</span>
            </div>
            <h3 class="mt-5 text-2xl font-black tracking-[-0.04em] text-[#f4fbff]">Products, apps, and platforms you use directly.</h3>
            <p class="mt-4 text-base leading-7 text-[#9dc6d8]">
              These are the software layers: writing tools, SEO platforms, email systems, automation tools, and productized AI apps.
            </p>
            <ul class="mt-6 space-y-3 text-sm leading-6 text-[#b7d8e5]">
              <li>Clear product identity and recognizable use case.</li>
              <li>Best when you need a platform decision or program comparison.</li>
              <li>Leads naturally into Programs for deeper review and affiliate context.</li>
            </ul>
          </article>

          <article class="rounded-[32px] border border-[#1a4560] bg-[linear-gradient(180deg,rgba(7,41,62,0.92),rgba(1,24,38,0.92))] p-7 shadow-[0_20px_50px_rgba(0,0,0,0.2)]">
            <div class="flex items-center justify-between gap-4">
              <span class="rounded-full border border-[#1f5f82] bg-[#2173A6]/15 px-3 py-2 text-[11px] font-semibold uppercase tracking-[0.24em] text-[#72DBF2]">Skills</span>
              <span class="text-sm text-[#89b8cb]">{skills.length} entries</span>
            </div>
            <h3 class="mt-5 text-2xl font-black tracking-[-0.04em] text-[#f4fbff]">Reusable workflows, capabilities, and operator modules.</h3>
            <p class="mt-4 text-base leading-7 text-[#9dc6d8]">
              These explain how the work gets done: research, writing, offer building, distribution, reporting, and operating the system cleanly.
            </p>
            <ul class="mt-6 space-y-3 text-sm leading-6 text-[#b7d8e5]">
              <li>Capability-driven instead of product-driven.</li>
              <li>Useful when you already know the job-to-be-done.</li>
              <li>Acts as the bridge between discovery and execution.</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section id="library" class="border-b border-[#0d2d40]">
      <div class="mx-auto max-w-7xl px-6 py-16 sm:px-8 lg:px-10">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-2xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#72DBF2]">Operating Library</p>
            <h2 class="mt-4 text-3xl font-black tracking-[-0.04em] text-[#f4fbff] sm:text-4xl">Find the right layer before you commit to the next step.</h2>
            <p class="mt-4 text-base leading-7 text-[#9dc6d8]">
              Filter by entity type first, then narrow by job family if you want a more specific operating route.
            </p>
          </div>
          <div class="rounded-3xl border border-[#14384f] bg-[#0B3B59]/25 px-4 py-3 text-sm text-[#89b8cb]">
            {libraryCounts.all} total entries across tools and skills
          </div>
        </div>

        <div class="mt-8 flex flex-wrap gap-3" data-mode-controls>
          <button class="library-filter-btn rounded-full border border-[#1a4560] bg-[#2173A6] px-4 py-2 text-sm font-semibold text-white" type="button" data-mode="all">
            All <span class="ml-1 opacity-70">{libraryCounts.all}</span>
          </button>
          <button class="library-filter-btn rounded-full border border-[#1a4560] bg-[#0B3B59]/45 px-4 py-2 text-sm font-semibold text-[#b7d8e5]" type="button" data-mode="tool">
            Tools <span class="ml-1 opacity-70">{libraryCounts.tools}</span>
          </button>
          <button class="library-filter-btn rounded-full border border-[#1a4560] bg-[#0B3B59]/45 px-4 py-2 text-sm font-semibold text-[#b7d8e5]" type="button" data-mode="skill">
            Skills <span class="ml-1 opacity-70">{libraryCounts.skills}</span>
          </button>
        </div>

        <div class="mt-4 flex flex-wrap gap-3" data-family-controls>
          <button class="library-family-btn rounded-full border border-[#1a4560] bg-[#2173A6]/15 px-4 py-2 text-sm font-semibold text-[#72DBF2]" type="button" data-family="all">
            All workflows
          </button>
          {Object.entries(categoryMeta).map(([key, meta]) => (
            <button class="library-family-btn rounded-full border border-[#1a4560] bg-[#0B3B59]/35 px-4 py-2 text-sm font-semibold text-[#9dc6d8]" type="button" data-family={key}>
              {meta.label}
            </button>
          ))}
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3" data-library-grid>
          {libraryItems.map((item) => (
            <article
              class:list={[
                'library-card relative overflow-hidden rounded-[30px] border border-[#14384f] shadow-[0_18px_40px_rgba(0,0,0,0.18)] transition duration-200',
                item.kind === 'tool'
                  ? 'bg-[linear-gradient(180deg,rgba(11,59,89,0.84),rgba(1,24,38,0.92))]'
                  : 'bg-[linear-gradient(180deg,rgba(7,41,62,0.92),rgba(4,23,36,0.96))]',
              ]}
              data-kind={item.kind}
              data-family={item.filterCategory}
            >
              <div class="absolute inset-0 opacity-[0.05]" style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.35) 0px, rgba(255,255,255,0.35) 1px, transparent 1px, transparent 14px);"></div>
              <div class="relative p-6">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0">
                    <span class:list={[
                      'inline-flex rounded-full border px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.22em]',
                      item.kind === 'tool'
                        ? 'border-[#1f5f82] bg-[#2173A6]/15 text-[#72DBF2]'
                        : 'border-[#36536a] bg-[#09283d] text-[#9dc6d8]',
                    ]}>
                      {item.kind === 'tool' ? 'Tool' : 'Skill'}
                    </span>
                  </div>
                  <span class="text-[11px] uppercase tracking-[0.2em] text-[#6f9ab0]">{item.label}</span>
                </div>

                {item.kind === 'tool' ? (
                  <div class="mt-6 flex items-center gap-4">
                    <ProgramLogo name={item.name} logo={item.tool.logo} size="sm" />
                    <div class="min-w-0">
                      <h3 class="text-xl font-black tracking-[-0.04em] text-[#f4fbff]">{item.name}</h3>
                      <p class="mt-1 text-sm text-[#89b8cb] capitalize">{item.tool.categoryLabel} tool</p>
                    </div>
                  </div>
                ) : (
                  <div class="mt-6 rounded-3xl border border-[#14384f] bg-[#08273b]/70 p-4">
                    <div class="flex items-center justify-between gap-4">
                      <h3 class="text-xl font-black tracking-[-0.04em] text-[#f4fbff]">{item.name}</h3>
                      <span class="rounded-full border border-[#36536a] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-[#9dc6d8]">
                        {item.skill.tier}
                      </span>
                    </div>
                    <p class="mt-2 text-sm text-[#89b8cb]">{item.skill.entityType.replace('-', ' ')}</p>
                  </div>
                )}

                <p class="mt-5 text-sm leading-7 text-[#b8d9e6]">{item.description}</p>

                <div class="mt-5 flex flex-wrap gap-2">
                  {item.tags.slice(0, 3).map((tag) => (
                    <span class="rounded-full border border-[#16374c] bg-[#08283d]/65 px-3 py-1.5 text-[11px] text-[#89b8cb]">
                      {tag}
                    </span>
                  ))}
                </div>

