  <script>
    const cards = Array.from(document.querySelectorAll('[data-library-grid] .library-card'));
    const modeButtons = Array.from(document.querySelectorAll('[data-mode-controls] .library-filter-btn'));
    const familyButtons = Array.from(document.querySelectorAll('[data-family-controls] .library-family-btn'));

    let activeMode = 'all';
    let activeFamily = 'all';

    const updateButtons = () => {
      modeButtons.forEach((button) => {
        const isActive = button.dataset.mode === activeMode;
        button.classList.toggle('bg-[#2173A6]', isActive);
        button.classList.toggle('text-white', isActive);
        button.classList.toggle('bg-[#0B3B59]/45', !isActive);
        button.classList.toggle('text-[#b7d8e5]', !isActive);
      });

      familyButtons.forEach((button) => {
        const isActive = button.dataset.family === activeFamily;
        button.classList.toggle('bg-[#2173A6]/15', isActive);
        button.classList.toggle('text-[#72DBF2]', isActive);
        button.classList.toggle('bg-[#0B3B59]/35', !isActive);
        button.classList.toggle('text-[#9dc6d8]', !isActive);
      });
    };

    const applyFilters = () => {
      cards.forEach((card) => {
        const matchesMode = activeMode === 'all' || card.dataset.kind === activeMode;
        const matchesFamily = activeFamily === 'all' || card.dataset.family === activeFamily;
        const visible = matchesMode && matchesFamily;
        card.classList.toggle('hidden', !visible);
      });
      updateButtons();
    };

    modeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeMode = button.dataset.mode ?? 'all';
        applyFilters();
      });
    });

    familyButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeFamily = button.dataset.family ?? 'all';
        applyFilters();
      });
    });

    applyFilters();
  </script>
</BaseLayout>
