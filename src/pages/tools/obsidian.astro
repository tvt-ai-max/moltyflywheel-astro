---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProgramLogo from '../../components/programs/ProgramLogo.astro';

const title = 'Obsidian Tool Detail | MoltyFlywheel';
const description =
  'A practical Obsidian overview for operators, creators, and researchers who want a Markdown knowledge base with local files, internal links, Canvas, and flexible sync options.';

const productSignals = [
  'Obsidian currently describes itself as both a Markdown editor and a knowledge base app.',
  'The official product emphasizes local plain-text files, internal links, and control over your own data.',
  'Canvas is positioned as a visual workspace for brainstorming, mapping ideas, and embedding notes or media in one view.',
  'Obsidian Sync is presented as an optional first-party add-on for private cross-device sync, while local and third-party file-based workflows remain valid.',
];

const strengths = [
  'Local Markdown storage is a strong fit for people who want portability, version control, and long-term file ownership.',
  'Internal links and graph-style note structures make it easier to build connected research systems rather than isolated documents.',
  'Canvas adds a practical visual layer for planning, research mapping, and multi-note workflows.',
  'The app is flexible enough for personal knowledge management, content research, workflow documentation, and operator SOP systems.',
];

const constraints = [
  'Obsidian is not a plug-and-play CRM or email automation system; it is a knowledge layer, not a full operational backend.',
  'The value is highest when you commit to an actual note structure and process, not just install the app and collect random notes.',
  'Teams may need separate decisions for sync, governance, and plugin discipline before scaling usage.',
  'If you only need quick note capture with no linked knowledge system, a lighter app may be enough.',
];

const bestFits = [
  'Operators who want a durable knowledge base for research, SOPs, workflow notes, and content planning.',
  'Creators who need a central place to connect ideas, outlines, source notes, and publishing workflows.',
  'Developers or researchers who prefer local Markdown files over closed-note platforms.',
];

const useCases = [
  'Build a personal or team knowledge base around linked notes instead of disconnected documents.',
  'Map research, article structure, and workflow planning inside Canvas before execution.',
  'Keep SOPs, prompt libraries, and content systems portable through local Markdown files.',
];
---

<BaseLayout title={title} description={description}>
  <section class="relative overflow-hidden border-b border-[#0d2d40] bg-[#011826]">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(114,219,242,0.14),transparent_32%),radial-gradient(circle_at_82%_18%,rgba(33,115,166,0.24),transparent_22%),linear-gradient(180deg,rgba(11,59,89,0.18),transparent_55%)]"></div>
    <div class="absolute inset-0 opacity-[0.08]" style="background-image: linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <div class="relative mx-auto max-w-[1400px] px-4 py-14 md:px-6 md:py-18">
      <div class="grid gap-10 xl:grid-cols-[minmax(0,1.15fr)_380px] xl:items-start">
        <div class="max-w-4xl">
          <nav class="flex items-center gap-2 text-xs text-[#3d7a96]" aria-label="Breadcrumb">
            <a href="/" class="transition-colors hover:text-[#72DBF2]">Home</a>
            <span>/</span>
            <a href="/tools" class="transition-colors hover:text-[#72DBF2]">Tools</a>
            <span>/</span>
            <span class="text-[#5ea4bf]">Obsidian</span>
          </nav>

          <div class="mt-5 flex flex-wrap items-center gap-2">
            <span class="inline-flex rounded-full border border-[#B8D9E8]/20 bg-[#B8D9E8]/10 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em] text-[#B8D9E8]">
              Knowledge Base
            </span>
            <span class="inline-flex rounded-full border border-[#72DBF2]/20 bg-[#72DBF2]/10 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em] text-[#72DBF2]">
              Tool Detail
            </span>
          </div>

          <h1 class="mt-6 max-w-4xl text-4xl font-black leading-[1.05] text-[#daeef5] md:text-6xl">
            Obsidian is worth using when your workflow needs a durable knowledge system, not just another note app.
          </h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-[#5ea4bf] md:text-[19px]">
            This page is the practical layer: what Obsidian is, why local Markdown matters, where Canvas fits, and when a connected note system actually improves execution.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-4">
            <div class="flex items-center gap-2 rounded-full border border-[#1a4560] bg-[#0B3B59]/70 px-4 py-2 text-sm font-medium text-[#89c0d4]">
              4.8 / 5 editorial fit
            </div>
            <div class="rounded-full border border-[#1a4560] bg-[#0B3B59]/70 px-4 py-2 text-sm font-medium text-[#89c0d4]">
              External platform
            </div>
            <div class="rounded-full border border-[#1a4560] bg-[#0B3B59]/70 px-4 py-2 text-sm font-medium text-[#89c0d4]">
              Markdown + links + Canvas
            </div>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="https://obsidian.md/"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center rounded-full bg-[#2173A6] px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#2d88bf]"
            >
              Open Obsidian →
            </a>
            <a
              href="https://help.obsidian.md/obsidian"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center rounded-full border border-[#72DBF2]/25 bg-[#72DBF2]/10 px-6 py-3 text-sm font-semibold text-[#72DBF2] transition-colors hover:bg-[#72DBF2]/16"
            >
              Read docs →
            </a>
          </div>
        </div>

        <div class="rounded-[28px] border border-[#1a4560] bg-[linear-gradient(160deg,rgba(11,59,89,0.96),rgba(1,24,38,0.92))] p-6 shadow-[0_28px_90px_rgba(1,24,38,0.35)]">
          <div class="relative overflow-hidden rounded-[24px] border border-[#1a4560] bg-[#011826]/50 p-5">
            <div class="absolute -left-10 -top-10 h-36 w-36 rounded-full blur-3xl bg-[#72DBF2]/20"></div>
            <div class="relative flex items-center gap-4">
              <ProgramLogo name="Obsidian" logo="" size="md" />
              <div>
                <p class="text-[11px] uppercase tracking-[0.24em] text-[#72DBF2]">Signal Snapshot</p>
                <h2 class="mt-2 text-2xl font-bold text-[#daeef5]">Linked note system</h2>
              </div>
            </div>
            <p class="mt-5 text-sm leading-7 text-[#89c0d4]">
              The strongest public signal is ownership and structure: local Markdown files, first-class links, and visual planning layers instead of cloud-only note dependency.
            </p>
          </div>

          <div class="mt-5 space-y-4">
            <div class="rounded-2xl border border-[#1a4560] bg-[#011826]/55 p-4">
              <p class="text-[11px] uppercase tracking-[0.24em] text-[#3d7a96]">Best for</p>
              <p class="mt-2 text-sm leading-6 text-[#daeef5]">Knowledge systems, research libraries, SOP hubs, and content planning workflows.</p>
            </div>
            <div class="rounded-2xl border border-[#1a4560] bg-[#011826]/55 p-4">
              <p class="text-[11px] uppercase tracking-[0.24em] text-[#3d7a96]">What stands out</p>
              <p class="mt-2 text-sm leading-6 text-[#daeef5]">Local files, internal links, Canvas, and optional first-party sync instead of forced cloud lock-in.</p>
            </div>
            <div class="rounded-2xl border border-[#1a4560] bg-[#011826]/55 p-4">
              <p class="text-[11px] uppercase tracking-[0.24em] text-[#3d7a96]">What to compare</p>
              <p class="mt-2 text-sm leading-6 text-[#daeef5]">Your note structure, sync needs, plugin discipline, and whether linked notes will actually improve your workflow.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="editorial-review" class="border-b border-[#0d2d40] bg-[#041f31]">
    <div class="mx-auto max-w-[1200px] px-4 py-14 md:px-6 md:py-18">
      <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_320px]">
        <article class="space-y-10">
          <section class="rounded-[28px] border border-[#1a4560] bg-[#0B3B59]/35 p-7">
            <h2 class="text-2xl font-bold text-[#daeef5]">What Obsidian Looks Like Right Now</h2>
            <p class="mt-4 text-base leading-8 text-[#9dc6d8]">
              Obsidian currently presents itself as a Markdown editor and knowledge base app. The key difference from many note apps is that the product treats local plain-text files and linked knowledge structures as the foundation, not as an export option.
            </p>
            <p class="mt-4 text-base leading-8 text-[#9dc6d8]">
              That matters because it changes the evaluation lens. Obsidian is not mainly about quick note capture. It is about building a durable system for ideas, research, planning, and documentation that remains usable outside one vendor’s cloud.
            </p>
          </section>

          <section class="rounded-[28px] border border-[#1a4560] bg-[#0B3B59]/35 p-7">
            <h2 class="text-2xl font-bold text-[#daeef5]">Current Product Signals</h2>
            <ul class="mt-5 space-y-3 text-sm leading-7 text-[#b8d9e6]">
              {productSignals.map((item) => <li>• {item}</li>)}
            </ul>
          </section>

          <section class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-[28px] border border-[#1a4560] bg-[#0B3B59]/35 p-7">
              <h2 class="text-2xl font-bold text-[#daeef5]">Good Fit</h2>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-[#b8d9e6]">
                {bestFits.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
            <div class="rounded-[28px] border border-[#1a4560] bg-[#0B3B59]/35 p-7">
              <h2 class="text-2xl font-bold text-[#daeef5]">Less Ideal Fit</h2>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-[#b8d9e6]">
                {constraints.slice(0, 3).map((item) => <li>• {item}</li>)}
              </ul>
            </div>
          </section>

          <section class="rounded-[28px] border border-[#1a4560] bg-[#0B3B59]/35 p-7">
            <h2 class="text-2xl font-bold text-[#daeef5]">What It Seems Best At</h2>
            <ul class="mt-5 space-y-3 text-sm leading-7 text-[#b8d9e6]">
              {useCases.map((item) => <li>• {item}</li>)}
            </ul>
          </section>

          <section class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-[28px] border border-[#1a4560] bg-[#0B3B59]/35 p-7">
              <h2 class="text-2xl font-bold text-[#daeef5]">Strengths</h2>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-[#b8d9e6]">
                {strengths.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
            <div class="rounded-[28px] border border-[#1a4560] bg-[#0B3B59]/35 p-7">
              <h2 class="text-2xl font-bold text-[#daeef5]">Constraints</h2>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-[#b8d9e6]">
                {constraints.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
          </section>

          <section class="rounded-[28px] border border-[#1a4560] bg-[#0B3B59]/35 p-7">
            <h2 class="text-2xl font-bold text-[#daeef5]">Related Paths</h2>
            <div class="mt-5 grid gap-4 md:grid-cols-2">
              <a href="/blog/how-openclaw-generates-1-blog-post-per-day/" class="rounded-2xl border border-[#1a4560] bg-[#011826]/55 p-4 text-sm leading-7 text-[#b8d9e6] transition hover:border-[#72DBF2]/35 hover:text-white">
                See how a documented content workflow benefits from a stronger knowledge layer →
              </a>
              <a href="/tools/" class="rounded-2xl border border-[#1a4560] bg-[#011826]/55 p-4 text-sm leading-7 text-[#b8d9e6] transition hover:border-[#72DBF2]/35 hover:text-white">
                Go back to the tools and skills operating library →
              </a>
              <a href="/programs/notion-ai/" class="rounded-2xl border border-[#1a4560] bg-[#011826]/55 p-4 text-sm leading-7 text-[#b8d9e6] transition hover:border-[#72DBF2]/35 hover:text-white">
                Compare Obsidian with a more workspace-style AI knowledge layer →
              </a>
              <a href="/search/" class="rounded-2xl border border-[#1a4560] bg-[#011826]/55 p-4 text-sm leading-7 text-[#b8d9e6] transition hover:border-[#72DBF2]/35 hover:text-white">
                Search adjacent workflow, research, and note-system content →
              </a>
            </div>
          </section>
        </article>

        <aside class="space-y-5">
          <div class="rounded-[28px] border border-[#1a4560] bg-[linear-gradient(180deg,rgba(11,59,89,0.9),rgba(1,24,38,0.92))] p-6">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#72DBF2]">Decision Note</p>
            <p class="mt-4 text-sm leading-7 text-[#b8d9e6]">
              Treat Obsidian as a system design decision. The key question is whether linked notes, local ownership, and visual planning will strengthen your actual research and execution process.
            </p>
          </div>

          <div class="rounded-[28px] border border-[#1a4560] bg-[linear-gradient(180deg,rgba(11,59,89,0.9),rgba(1,24,38,0.92))] p-6">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#72DBF2]">Next Click</p>
            <a
              href="https://obsidian.md/"
              target="_blank"
              rel="noreferrer"
              class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-[#2173A6] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#2d88bf]"
            >
              Open Obsidian →
            </a>
            <p class="mt-4 text-xs leading-6 text-[#89c0d4]">
              External platform. Check the live docs, plugin ecosystem, and sync model before rolling it out across a team workflow.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
