---
import { getCollection, render } from 'astro:content';
import OfferLayout from '../../layouts/OfferLayout.astro';
import AffiliateButton from '../../components/affiliate/AffiliateButton.astro';

export async function getStaticPaths() {
  const offers = await getCollection('offers', ({ data }) => !data.draft);
  return offers.map(offer => ({ params: { offer: offer.id }, props: { offer } }));
}

const { offer } = Astro.props;
const programs = await getCollection('programs');
const matchedProgram = programs.find((program) => program.id === offer.data.targetProgram);
const { Content } = await render(offer);
---
<OfferLayout title={offer.data.title} description={offer.data.headline}>
  <section class="bg-[#f7fbfd]">
    <div class="mx-auto max-w-5xl px-6 py-20 md:py-24">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-[#2173A6]/20 bg-[#2173A6]/8 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-[#2173A6]">
          Offer Page
        </div>
        <h1 class="mt-8 text-4xl font-black leading-tight text-[#0b2230] md:text-6xl">
          {offer.data.headline}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-[#476879]">
          A decision-first page designed to help the reader judge fit, constraints, and the most practical next click before committing.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <AffiliateButton program={offer.data.targetProgram} label={offer.data.cta} size="lg" />
          <a href="#offer-details" class="inline-flex items-center rounded-lg border-2 border-[#2173A6] px-6 py-3 text-sm font-semibold text-[#2173A6] transition-colors hover:bg-[#2173A6]/8">
            Read the details
          </a>
        </div>
      </div>

      <div class="mt-12 rounded-[28px] border border-[#d8e7ee] bg-white p-8 shadow-[0_18px_60px_rgba(11,59,89,0.08)]">
        <div class="grid gap-4 md:grid-cols-3">
          <div class="rounded-2xl border border-[#e3eef3] bg-[#f8fcfe] p-5">
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#5c8294]">Best for</p>
            <p class="mt-3 text-sm leading-7 text-[#2d4b5a]">Readers who need a clearer decision frame before choosing a tool, program, or platform.</p>
          </div>
          <div class="rounded-2xl border border-[#e3eef3] bg-[#f8fcfe] p-5">
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#5c8294]">Primary angle</p>
            <p class="mt-3 text-sm leading-7 text-[#2d4b5a]">Decision support first, promotion second, with fit and trade-offs kept explicit.</p>
          </div>
          <div class="rounded-2xl border border-[#e3eef3] bg-[#f8fcfe] p-5">
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#5c8294]">CTA logic</p>
            <p class="mt-3 text-sm leading-7 text-[#2d4b5a]">Click through only when the use case, constraints, and operating reality all line up.</p>
          </div>
        </div>
      </div>

      <div
        id="offer-details"
        class="mt-14 rounded-[28px] border border-[#d8e7ee] bg-white px-6 py-8 shadow-[0_18px_60px_rgba(11,59,89,0.08)] md:px-8 md:py-10
        [&_h2]:mt-12 [&_h2]:border-l-4 [&_h2]:border-[#2173A6] [&_h2]:pl-4 [&_h2]:text-3xl [&_h2]:font-bold [&_h2]:leading-tight [&_h2]:text-[#0b2230]
        [&_h3]:mt-8 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-[#16384a]
        [&_h4]:mt-6 [&_h4]:text-lg [&_h4]:font-semibold [&_h4]:text-[#21485d]
        [&_p]:mb-5 [&_p]:text-base [&_p]:leading-8 [&_p]:text-[#355564]
        [&_strong]:font-semibold [&_strong]:text-[#0b2230]
        [&_em]:text-[#21485d]
        [&_a]:font-medium [&_a]:text-[#2173A6] [&_a]:underline [&_a]:underline-offset-4
        [&_ul]:mb-5 [&_ul]:list-disc [&_ul]:pl-6
        [&_ol]:mb-5 [&_ol]:list-decimal [&_ol]:pl-6
        [&_li]:mb-2 [&_li]:leading-8 [&_li]:text-[#355564]
        [&_blockquote]:my-8 [&_blockquote]:rounded-r-xl [&_blockquote]:border-l-4 [&_blockquote]:border-[#2173A6] [&_blockquote]:bg-[#f4f9fb] [&_blockquote]:px-5 [&_blockquote]:py-4 [&_blockquote]:text-[#21485d]
        [&_hr]:my-10 [&_hr]:border-[#d8e7ee]
        [&_code]:rounded [&_code]:bg-[#edf6fa] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-[#0B3B59]
        [&_pre]:my-6 [&_pre]:overflow-x-auto [&_pre]:rounded-2xl [&_pre]:border [&_pre]:border-[#d8e7ee] [&_pre]:bg-[#0b2230] [&_pre]:p-5
        [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-[#daeef5]
        [&_table]:my-8 [&_table]:w-full [&_table]:border-collapse
        [&_thead_th]:border-b-2 [&_thead_th]:border-[#d8e7ee] [&_thead_th]:bg-[#f4f9fb] [&_thead_th]:px-4 [&_thead_th]:py-3 [&_thead_th]:text-left [&_thead_th]:text-xs [&_thead_th]:font-semibold [&_thead_th]:uppercase [&_thead_th]:tracking-[0.08em] [&_thead_th]:text-[#21485d]
        [&_tbody_td]:border-b [&_tbody_td]:border-[#e3eef3] [&_tbody_td]:px-4 [&_tbody_td]:py-3 [&_tbody_td]:text-sm [&_tbody_td]:text-[#355564]
        [&_img]:my-6 [&_img]:rounded-2xl"
      >
        <Content />
      </div>

      <div class="mt-14 rounded-[28px] border border-[#cfe2ea] bg-[linear-gradient(135deg,#0B3B59_0%,#2173A6_58%,#72DBF2_100%)] p-8 text-white shadow-[0_22px_70px_rgba(11,59,89,0.22)]">
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-white/75">Final CTA</p>
        <h2 class="mt-3 text-3xl font-black leading-tight">Take the next step only if {offer.data.title} matches the real need, not just the surface pitch.</h2>
        <p class="mt-4 max-w-3xl text-base leading-8 text-[#e9f7fc]">
          The strongest offer pages on MoltyFlywheel help the reader move with better judgment, not faster hype. If the fit is real, use the CTA. If not, take the related path that solves the earlier bottleneck first.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <AffiliateButton program={offer.data.targetProgram} label={offer.data.cta} size="lg" />
          {matchedProgram ? (
            <a href={`/programs/${matchedProgram.id}`} class="inline-flex items-center rounded-lg bg-white px-6 py-3 text-sm font-semibold text-[#0B3B59] transition-transform hover:-translate-y-0.5">
              View {matchedProgram.data.name} Review
            </a>
          ) : (
            <a href="/offers/" class="inline-flex items-center rounded-lg bg-white px-6 py-3 text-sm font-semibold text-[#0B3B59] transition-transform hover:-translate-y-0.5">
              Browse Offer Pages
            </a>
          )}
        </div>
        <p class="mt-4 text-xs italic text-white/80">
          Offer pages should only promise assets, outcomes, and next steps that are already real in the live system.
        </p>
      </div>
    </div>
  </section>
</OfferLayout>
