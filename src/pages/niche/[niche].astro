---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateButton from '../../components/affiliate/AffiliateButton.astro';

export async function getStaticPaths() {
  const niches = await getCollection('niches');
  return niches.map(niche => ({ params: { niche: niche.id }, props: { niche } }));
}

const { niche } = Astro.props;
const { Content } = await render(niche);

// Get related programs (fetch full program data for name/description)
const allPrograms = await getCollection('programs');
const relatedPrograms = allPrograms.filter(p =>
  niche.data.programs && niche.data.programs.includes(p.id)
);

// Get related blog posts: match by affiliatePrograms field overlapping with niche programs
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(p =>
    p.data.affiliatePrograms?.some((prog: string) =>
      niche.data.programs && niche.data.programs.includes(prog)
    )
  )
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout title={`${niche.data.title} — MoltyFlywheel`} description={niche.data.description}>
  <div class="max-w-6xl mx-auto px-6 py-16">

    <!-- Header -->
    <div class="max-w-3xl mb-12">
      <h1 class="text-4xl font-black mb-4">{niche.data.title}</h1>
      <p class="text-gray-400 text-xl leading-relaxed">{niche.data.description}</p>
    </div>

    <!-- Keywords -->
    {niche.data.keywords && niche.data.keywords.length > 0 && (
      <div class="bg-amber-500/5 border border-amber-500/20 rounded-2xl p-5 mb-12">
        <h3 class="text-xs font-bold text-amber-500 uppercase tracking-wider mb-3">Target Keywords</h3>
        <div class="flex flex-wrap gap-2">
          {niche.data.keywords.map((kw: string) => (
            <span class="bg-gray-800 text-gray-300 text-xs px-3 py-1 rounded-full">{kw}</span>
          ))}
        </div>
      </div>
    )}

    <!-- Related Programs -->
    {relatedPrograms.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold mb-6">Top Programs in This Niche</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedPrograms.map(p => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-amber-500/30 transition-colors">
              <div class="flex items-start justify-between mb-2">
                <span class="text-xs bg-amber-500/10 text-amber-400 border border-amber-500/20 px-2 py-0.5 rounded font-semibold uppercase">
                  {p.data.category}
                </span>
                {p.data.commission && (
                  <span class="text-xs text-green-400 font-semibold">{p.data.commission.rate}</span>
                )}
              </div>
              <h3 class="font-bold text-white mt-2 mb-1">{p.data.name}</h3>
              <p class="text-gray-400 text-sm mb-4 line-clamp-2">{p.data.description}</p>
              <div class="flex items-center gap-3">
                <a href={`/programs/${p.id}`} class="text-amber-500 hover:underline text-sm font-medium">Review →</a>
                <AffiliateButton program={p.id} label="Join" size="sm" />
              </div>
            </div>
          ))}
        </div>
        <div class="mt-6">
          <a href="/programs" class="text-gray-500 hover:text-gray-400 text-sm">View all affiliate programs →</a>
        </div>
      </section>
    )}

    <!-- Main Content -->
    <div class="prose prose-invert prose-amber max-w-none mb-16">
      <Content />
    </div>

    <!-- Related Blog Posts -->
    {relatedPosts.length > 0 && (
      <section class="border-t border-gray-800 pt-12">
        <h2 class="text-2xl font-bold mb-6">Related Articles</h2>
        <div class="grid md:grid-cols-3 gap-5">
          {relatedPosts.map(post => (
            <a
              href={`/blog/${post.id}`}
              class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-amber-500/50 transition-all group"
            >
              <span class="text-xs text-amber-500 uppercase tracking-wider font-semibold">{post.data.category}</span>
              <h3 class="font-semibold text-white mt-2 leading-snug group-hover:text-amber-400 transition-colors">
                {post.data.title}
              </h3>
            </a>
          ))}
        </div>
        <div class="mt-6">
          <a href="/blog" class="text-gray-500 hover:text-gray-400 text-sm">View all posts →</a>
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <div class="mt-16 p-8 bg-gradient-to-br from-amber-500/10 to-transparent border border-amber-500/20 rounded-2xl text-center">
      <h3 class="text-2xl font-bold mb-3">Build Your {niche.data.title} Flywheel</h3>
      <p class="text-gray-400 mb-6">52 AI skills. $71/month. $3,810/month target ROI.</p>
      <a href="/free-guide" class="inline-flex items-center px-8 py-4 bg-[#2173A6] hover:bg-[#1a5d8c] text-white font-bold rounded-lg transition-all shadow-lg">
        Get the Free Guide →
      </a>
    </div>

  </div>
</BaseLayout>
