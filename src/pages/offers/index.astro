---
import BaseLayout from '../../layouts/BaseLayout.astro';

const offerPages = [
  {
    title: 'Find Your Best Affiliate Fit',
    href: '/offers/find-your-best-affiliate-fit',
    type: 'Decision page',
    description: 'Start here if you need help choosing the most practical affiliate direction for your current stage.',
  },
  {
    title: 'Best Affiliate Programs For Beginners',
    href: '/offers/best-affiliate-programs-for-beginners',
    type: 'Beginner offer page',
    description: 'A cleaner shortlist for readers who want easier programs to understand, promote, and grow into.',
  },
  {
    title: 'Recurring Commission Affiliate Programs',
    href: '/offers/recurring-commission-affiliate-programs',
    type: 'Recurring page',
    description: 'Explore offers that support steadier long-term payout logic instead of one-off commissions only.',
  },
  {
    title: 'High-Ticket Affiliate Programs',
    href: '/offers/high-ticket-affiliate-programs',
    type: 'High-ticket page',
    description: 'Compare offer types where higher-value conversions matter more than raw volume.',
  },
  {
    title: 'Affiliate Programs By Niche',
    href: '/offers/affiliate-programs-by-niche',
    type: 'Fit page',
    description: 'Match the monetization path to your niche so the offer logic fits the audience you already have.',
  },
  {
    title: 'Compare Affiliate Platforms',
    href: '/offers/compare-affiliate-platforms',
    type: 'Comparison page',
    description: 'Use this page when platform choice is the real decision bottleneck behind your monetization plan.',
  },
  {
    title: 'Affiliate Tools For Content Creators',
    href: '/offers/affiliate-tools-for-content-creators',
    type: 'Workflow page',
    description: 'A practical guide for creators who need tools and offers that support a repeatable publishing workflow.',
  },
];
---

<BaseLayout
  title="Offer Pages — MoltyFlywheel"
  description="Decision-first offer pages for recurring programs, beginner-friendly picks, high-ticket paths, and affiliate fit."
>
  <section class="border-b border-[#0d2d40] bg-[radial-gradient(circle_at_top,#0B3B59_0%,#011826_58%,#01131d_100%)]">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
      <div class="max-w-3xl">
        <div class="inline-flex items-center rounded-full border border-[#2173A6]/40 bg-[#2173A6]/12 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#72DBF2]">
          Offer Hub
        </div>
        <h1 class="mt-6 text-4xl font-black leading-tight text-[#daeef5] md:text-6xl">
          Offer pages built for clearer affiliate decisions.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[#89c0d4]">
          Use these pages when you want a more guided path than a standard program directory. Each page is designed to help readers choose the right fit, not just click the loudest CTA.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-[#011826] py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-10 flex items-end justify-between gap-6">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#72DBF2]">Current Offer Pages</p>
          <h2 class="mt-3 text-3xl font-black text-[#daeef5]">Browse by the kind of decision you need to make.</h2>
        </div>
        <p class="text-sm text-[#5ea4bf]">{offerPages.length} pages</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {offerPages.map((page) => (
          <a
            href={page.href}
            class="group rounded-[24px] border border-[#0d2d40] bg-[linear-gradient(180deg,rgba(11,59,89,0.92),rgba(4,26,39,0.96))] p-7 transition-transform duration-200 hover:-translate-y-1 hover:border-[#2173A6]"
          >
            <div class="inline-flex rounded-full border border-[#2173A6]/40 bg-[#2173A6]/12 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-[#72DBF2]">
              {page.type}
            </div>
            <h3 class="mt-5 text-2xl font-black leading-tight text-[#daeef5] transition-colors group-hover:text-white">
              {page.title}
            </h3>
            <p class="mt-4 text-sm leading-7 text-[#89c0d4]">
              {page.description}
            </p>
            <div class="mt-6 flex items-center justify-between border-t border-[#0d2d40] pt-5 text-sm font-semibold text-[#72DBF2]">
              <span>Open page</span>
              <span aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-14 rounded-[28px] border border-[#0d2d40] bg-[linear-gradient(135deg,rgba(11,59,89,0.9),rgba(33,115,166,0.88))] p-8 md:p-10">
        <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
          <div class="max-w-2xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-white/70">Need a faster starting point?</p>
            <h3 class="mt-3 text-2xl font-black text-white">If you are still early, start with the page that helps you choose the right fit first.</h3>
            <p class="mt-3 text-sm leading-7 text-[#e4f5fb]">
              That usually gives better results than forcing a single high-ticket or recurring path before your audience, niche, and workflow are clear.
            </p>
          </div>
          <a
            href="/offers/find-your-best-affiliate-fit"
            class="inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 text-sm font-semibold text-[#0B3B59] transition-transform hover:-translate-y-0.5"
          >
            Start With Best-Fit Offers
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
