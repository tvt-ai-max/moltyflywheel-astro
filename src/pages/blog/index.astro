---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const urlCategory = Astro.url.searchParams.get('category') ?? 'all';
const filteredPosts = urlCategory === 'all'
  ? allPosts
  : allPosts.filter((post) => post.data.category === urlCategory);

const categoryLabel: Record<string, string> = {
  guide: 'Guide',
  review: 'Review',
  comparison: 'Comparison',
  'case-study': 'Case Study',
  tutorial: 'Tutorial',
};

const categories = [
  { id: 'all', label: 'All Posts', count: allPosts.length },
  { id: 'guide', label: 'Guides', count: allPosts.filter((post) => post.data.category === 'guide').length },
  { id: 'review', label: 'Reviews', count: allPosts.filter((post) => post.data.category === 'review').length },
  { id: 'comparison', label: 'Comparisons', count: allPosts.filter((post) => post.data.category === 'comparison').length },
  { id: 'case-study', label: 'Case Studies', count: allPosts.filter((post) => post.data.category === 'case-study').length },
  { id: 'tutorial', label: 'Tutorials', count: allPosts.filter((post) => post.data.category === 'tutorial').length },
].filter((category) => category.id === 'all' || category.count > 0);

const categoryStyle: Record<string, { badge: string; gradient: string; icon: string }> = {
  comparison: {
    badge: 'text-[#72DBF2] bg-[#72DBF2]/10 border border-[#72DBF2]/25',
    gradient: 'from-[#0B3B59] via-[#2173A6] to-[#72DBF2]',
    icon: 'CL',
  },
  review: {
    badge: 'text-[#72DBF2] bg-[#72DBF2]/10 border border-[#72DBF2]/25',
    gradient: 'from-[#011826] via-[#0B3B59] to-[#2173A6]',
    icon: 'RV',
  },
  guide: {
    badge: 'text-[#72DBF2] bg-[#72DBF2]/10 border border-[#72DBF2]/25',
    gradient: 'from-[#011826] via-[#0d2d40] to-[#2173A6]',
    icon: 'GD',
  },
  'case-study': {
    badge: 'text-[#72DBF2] bg-[#72DBF2]/10 border border-[#72DBF2]/25',
    gradient: 'from-[#0B3B59] via-[#1a4560] to-[#72DBF2]',
    icon: 'CS',
  },
  tutorial: {
    badge: 'text-[#72DBF2] bg-[#72DBF2]/10 border border-[#72DBF2]/25',
    gradient: 'from-[#011826] via-[#2173A6] to-[#5EA4BF]',
    icon: 'TU',
  },
};

function getCategoryStyle(category: string) {
  return categoryStyle[category] ?? {
    badge: 'text-[#72DBF2] bg-[#72DBF2]/10 border border-[#72DBF2]/25',
    gradient: 'from-[#011826] via-[#0B3B59] to-[#2173A6]',
    icon: 'AI',
  };
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function estimateReadTime(body?: string) {
  const words = body?.trim().split(/\s+/).filter(Boolean).length ?? 0;
  return Math.max(2, Math.round(words / 220));
}

function getThumbnail(post: typeof allPosts[number]) {
  return post.data.ogImage ?? post.data.og_image ?? null;
}

const featuredSource = urlCategory === 'all' ? allPosts : filteredPosts;
const explicitlyFeatured = featuredSource.filter((post) => post.data.featured);
const fallbackFeatured = featuredSource.filter((post) => !explicitlyFeatured.some((item) => item.id === post.id));
const editorialFeatures = [...explicitlyFeatured, ...fallbackFeatured]
  .slice(0, 2)
  .map((post) => ({
    ...post,
    thumbnail: getThumbnail(post),
    readTime: estimateReadTime(post.body),
    searchIndex: [
      post.data.title,
      post.data.description,
      ...(post.data.tags ?? []),
      post.data.category,
      categoryLabel[post.data.category] ?? post.data.category,
    ].join(' ').toLowerCase(),
  }));

const articleCards = filteredPosts.map((post) => ({
  ...post,
  thumbnail: getThumbnail(post),
  readTime: estimateReadTime(post.body),
  searchIndex: [
    post.data.title,
    post.data.description,
    ...(post.data.tags ?? []),
    post.data.category,
    categoryLabel[post.data.category] ?? post.data.category,
  ].join(' ').toLowerCase(),
}));

const socialProof = [
  `${allPosts.length}+ articles published`,
  '2,400+ readers/month',
  'Updated weekly',
];
---

<BaseLayout
  title="Blog — AI Affiliate Marketing Guides & Reviews | MoltyFlywheel"
  description="In-depth guides, tool reviews, and case studies to help you build a sustainable AI affiliate income. Updated weekly by the MoltyFlywheel team."
>
  <section
    class="relative overflow-hidden border-b border-[#0d2d40]"
    style="background: radial-gradient(circle at top right, rgba(114,219,242,0.12) 0%, transparent 30%), linear-gradient(135deg, #011826 0%, #0B3B59 52%, #011826 100%);"
  >
    <div
      class="absolute inset-0 opacity-[0.05] pointer-events-none"
      style="background-image: linear-gradient(rgba(114,219,242,0.7) 1px, transparent 1px), linear-gradient(90deg, rgba(114,219,242,0.7) 1px, transparent 1px); background-size: 42px 42px;"
    ></div>
    <div class="relative max-w-[1400px] mx-auto px-4 md:px-6 py-16 md:py-24">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_360px] lg:items-end">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 rounded-full border border-[#72DBF2]/25 bg-[#72DBF2]/10 px-4 py-2 mb-6">
            <span class="h-2 w-2 rounded-full bg-[#72DBF2]"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#72DBF2]">Editorial Hub</span>
          </div>

          <h1 class="text-[42px] leading-[1.02] md:text-[64px] font-black text-[#daeef5] max-w-4xl">
            AI affiliate strategy, written like an operator's playbook.
          </h1>

          <p class="mt-6 max-w-2xl text-[17px] leading-8 text-[#5ea4bf]">
            Browse deep guides, honest tool reviews, and comparison-led content built to help you pick better offers,
            sharper workflows, and more durable affiliate systems.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {socialProof.map((item) => (
              <span class="inline-flex items-center rounded-full border border-[#1a4560] bg-[#011826]/70 px-4 py-2 text-xs font-medium text-[#89c0d4]">
                {item}
              </span>
            ))}
          </div>
        </div>

        <div class="rounded-[28px] border border-[#1a4560] bg-[#011826]/80 p-6 md:p-7 backdrop-blur">
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#72DBF2]">Free Newsletter</p>
          <h2 class="mt-3 text-2xl font-bold leading-tight text-[#daeef5]">Get the AI affiliate playbook in your inbox.</h2>
          <p class="mt-3 text-sm leading-7 text-[#5ea4bf]">
            Weekly strategy notes, practical breakdowns, and real-world content ideas without the recycled hype.
          </p>

          <div class="mt-6 flex flex-col gap-3">
            <input
              type="email"
              placeholder="your@email.com"
              class="w-full rounded-2xl border border-[#1a4560] bg-[#0B3B59] px-4 py-3 text-sm text-[#daeef5] outline-none transition-colors placeholder:text-[#3d7a96] focus:border-[#72DBF2]"
            />
            <a
              href="/free-guide"
              class="inline-flex items-center justify-center rounded-2xl bg-[#2173A6] px-4 py-3 text-sm font-bold text-white transition-all hover:-translate-y-0.5 hover:bg-[#1a5d8c]"
            >
              Get the Free Guide →
            </a>
          </div>

          <p class="mt-3 text-xs text-[#3d7a96]">No spam. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="sticky top-[64px] z-40 border-b border-[#0d2d40] bg-[#011826]/95 backdrop-blur">
    <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-4">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex flex-wrap gap-2">
          {categories.map((category) => (
            <a
              href={category.id === 'all' ? '/blog' : `/blog?category=${category.id}`}
              class:list={[
                'inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold transition-all',
                urlCategory === category.id
                  ? 'bg-[#2173A6] text-white'
                  : 'border border-[#1a4560] bg-[#0B3B59] text-[#5ea4bf] hover:border-[#72DBF2]/30 hover:text-[#daeef5]',
              ]}
            >
              <span>{category.label}</span>
              <span class="rounded-full bg-black/10 px-1.5 py-0.5 text-[10px]">{category.count}</span>
            </a>
          ))}
        </div>

        <div class="relative w-full lg:w-[320px]">
          <svg class="absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-[#3d7a96]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input
            id="blog-search"
            type="text"
            placeholder="Search guides, reviews, and comparisons"
            class="w-full rounded-full border border-[#1a4560] bg-[#0B3B59] py-3 pl-11 pr-4 text-sm text-[#daeef5] outline-none transition-colors placeholder:text-[#3d7a96] focus:border-[#72DBF2]"
          />
          <button
            id="blog-search-clear"
            type="button"
            class="absolute right-3 top-1/2 hidden h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full border border-[#1a4560] bg-[#011826] text-[#89c0d4] transition-colors hover:border-[#72DBF2]/35 hover:text-[#daeef5]"
            aria-label="Clear blog search"
          >
            ×
          </button>
        </div>
      </div>
    </div>
  </section>

  {editorialFeatures.length > 0 && (
    <section id="featured-reads-section" class="border-b border-[#0d2d40] bg-[#011826]">
      <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-10 md:py-12">
        <div class="mb-6 flex items-center justify-between gap-4">
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#72DBF2]">Featured Reads</p>
            <h2 class="mt-2 text-2xl font-bold text-[#daeef5]">Editorial picks worth starting with</h2>
          </div>
          <p class="hidden md:block text-sm text-[#5ea4bf]">Hand-picked from the latest high-intent content</p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {editorialFeatures.map((post) => {
            const style = getCategoryStyle(post.data.category);
            const label = categoryLabel[post.data.category] ?? post.data.category;

            return (
              <a
                href={`/blog/${post.id}`}
                data-search={post.searchIndex}
                data-featured-card
                class="group overflow-hidden rounded-[28px] border border-[#1a4560] bg-[#0B3B59] transition-all hover:-translate-y-1 hover:border-[#72DBF2]/40 hover:shadow-2xl hover:shadow-[#011826]"
              >
                <div class="grid min-h-full md:grid-cols-[1.1fr_minmax(0,1fr)]">
                  <div class="relative min-h-[240px] overflow-hidden">
                    {post.thumbnail ? (
                      <>
                        <div
                          class="absolute inset-0 bg-gradient-to-br from-[#011826] via-[#0B3B59] to-[#1a4560]"
                        ></div>
                        <div
                          class="absolute inset-0 opacity-[0.08]"
                          style="background-image: radial-gradient(circle at 22% 18%, rgba(255,255,255,0.18) 0%, transparent 28%), repeating-linear-gradient(45deg, rgba(255,255,255,0.38) 0px, rgba(255,255,255,0.38) 1px, transparent 1px, transparent 14px);"
                        ></div>
                        <img
                          src={post.thumbnail}
                          alt={post.data.title}
                          loading="lazy"
                          decoding="async"
                          class="absolute inset-0 h-full w-full object-contain p-4 md:p-5 transition-transform duration-300 group-hover:scale-[1.02]"
                        />
                      </>
                    ) : (
                      <div class:list={['h-full w-full bg-gradient-to-br', style.gradient]}>
                        <div
                          class="absolute inset-0 opacity-[0.08]"
                          style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.6) 0px, rgba(255,255,255,0.6) 1px, transparent 1px, transparent 14px);"
                        ></div>
                        <div class="absolute inset-x-0 top-0 flex items-center justify-between px-5 py-5">
                          <span class:list={['rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em]', style.badge]}>
                            {label}
                          </span>
                          <span class="text-lg font-black tracking-[0.18em] text-white/25">{style.icon}</span>
                        </div>
                      </div>
                    )}
                    <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-[#011826] via-[#011826]/55 to-transparent px-5 pb-5 pt-12">
                      <span class:list={['inline-flex rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em]', style.badge]}>
                        {label}
                      </span>
                    </div>
                  </div>

                  <div class="flex flex-col p-6">
                    <div class="flex items-center gap-3 text-xs text-[#3d7a96]">
                      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                      <span class="text-[#1a4560]">•</span>
                      <span>{post.readTime} min read</span>
                    </div>

                    <h3 class="mt-4 text-[24px] font-bold leading-tight text-[#daeef5] transition-colors group-hover:text-[#72DBF2]">
                      {post.data.title}
                    </h3>

                    <p class="mt-4 flex-1 text-sm leading-7 text-[#5ea4bf]">
                      {post.data.description}
                    </p>

                    <div class="mt-6 flex items-center justify-between border-t border-[#0d2d40] pt-4">
                      <span class="text-xs font-medium text-[#89c0d4]">MoltyFlywheel Editorial</span>
                      <span class="text-sm font-bold text-[#72DBF2] transition-transform group-hover:translate-x-1">
                        Read article →
                      </span>
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <section class="bg-[#011826]">
    <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-10 md:py-14">
      <div class="mb-8 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#72DBF2]">Latest Articles</p>
          <h2 class="mt-2 text-3xl font-bold text-[#daeef5]">Browse the full content hub</h2>
        </div>
        <p id="results-count" class="text-sm text-[#5ea4bf]">
          {articleCards.length} article{articleCards.length !== 1 ? 's' : ''}
          {urlCategory !== 'all' ? ` in ${categoryLabel[urlCategory] ?? urlCategory}` : ''}
        </p>
      </div>

      <div id="blog-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
        {articleCards.map((post) => {
          const style = getCategoryStyle(post.data.category);
          const label = categoryLabel[post.data.category] ?? post.data.category;

          return (
            <article
              class="blog-card group flex h-full flex-col overflow-hidden rounded-[24px] border border-[#1a4560] bg-[#0B3B59] transition-all hover:-translate-y-1 hover:border-[#72DBF2]/40 hover:shadow-2xl hover:shadow-[#011826]"
              data-search={post.searchIndex}
            >
              <a href={`/blog/${post.id}`} class="relative block h-52 overflow-hidden">
                {post.thumbnail ? (
                  <>
                    <div
                      class="absolute inset-0 bg-gradient-to-br from-[#011826] via-[#0B3B59] to-[#1a4560]"
                    ></div>
                    <div
                      class="absolute inset-0 opacity-[0.08]"
                      style="background-image: radial-gradient(circle at 20% 18%, rgba(255,255,255,0.18) 0%, transparent 26%), repeating-linear-gradient(45deg, rgba(255,255,255,0.36) 0px, rgba(255,255,255,0.36) 1px, transparent 1px, transparent 15px);"
                    ></div>
                    <img
                      src={post.thumbnail}
                      alt={post.data.title}
                      loading="lazy"
                      decoding="async"
                      class="absolute inset-0 h-full w-full object-contain p-3 transition-transform duration-300 group-hover:scale-[1.02]"
                    />
                  </>
                ) : (
                  <div class:list={['h-full w-full bg-gradient-to-br', style.gradient]}>
                    <div
                      class="absolute inset-0 opacity-[0.07]"
                      style="background-image: radial-gradient(circle at 18% 20%, rgba(255,255,255,0.18) 0%, transparent 28%), repeating-linear-gradient(45deg, rgba(255,255,255,0.5) 0px, rgba(255,255,255,0.5) 1px, transparent 1px, transparent 15px);"
                    ></div>
                    <div class="absolute right-5 top-5 text-xl font-black tracking-[0.24em] text-white/20">{style.icon}</div>
                  </div>
                )}

                <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-[#011826] via-[#011826]/45 to-transparent px-5 pb-5 pt-14">
                  <span class:list={['inline-flex rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em]', style.badge]}>
                    {label}
                  </span>
                </div>
              </a>

              <div class="flex flex-1 flex-col p-5">
                <div class="flex items-center gap-3 text-[11px] text-[#3d7a96]">
                  <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                  <span class="text-[#1a4560]">•</span>
                  <span>{post.readTime} min read</span>
                </div>

                <a href={`/blog/${post.id}`} class="mt-4 block">
                  <h3 class="text-[18px] font-bold leading-snug text-[#daeef5] transition-colors group-hover:text-[#72DBF2]">
                    {post.data.title}
                  </h3>
                </a>

                <p class="mt-3 flex-1 text-sm leading-7 text-[#5ea4bf]">
                  {post.data.description}
                </p>

                {(post.data.tags ?? []).length > 0 && (
                  <div class="mt-5 flex flex-wrap gap-2">
                    {(post.data.tags ?? []).slice(0, 3).map((tag) => (
                      <span class="rounded-full border border-[#0d2d40] bg-[#011826] px-2.5 py-1 text-[10px] font-medium text-[#89c0d4]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                <div class="mt-5 flex items-center justify-between border-t border-[#0d2d40] pt-4">
                  <span class="text-xs font-medium text-[#89c0d4]">MoltyFlywheel Editorial</span>
                  <span class="text-sm font-bold text-[#72DBF2] transition-transform group-hover:translate-x-1">
                    Read →
                  </span>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <div id="empty-state" class="hidden flex-col items-center justify-center rounded-[24px] border border-dashed border-[#1a4560] bg-[#0B3B59]/35 px-6 py-20 text-center">
        <div class="text-5xl text-[#72DBF2]">/</div>
        <h3 class="mt-4 text-xl font-bold text-[#daeef5]">No articles matched that search</h3>
        <p class="mt-2 max-w-md text-sm leading-7 text-[#5ea4bf]">
          Try a broader keyword, switch categories, or clear the current query to see the full editorial archive.
        </p>
        <button id="empty-state-clear" type="button" class="mt-6 text-sm font-semibold text-[#72DBF2] hover:text-[#daeef5]">Clear search →</button>
      </div>
    </div>
  </section>

  <section class="border-t border-[#0d2d40] bg-[#0B3B59]">
    <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-14 md:py-16">
      <div
        class="relative overflow-hidden rounded-[28px] border border-[#72DBF2]/20"
        style="background: linear-gradient(135deg, #0B3B59 0%, #2173A6 55%, #5EA4BF 100%);"
      >
        <div class="absolute -right-20 -top-20 h-56 w-56 rounded-full bg-white/5"></div>
        <div class="absolute -bottom-16 -left-16 h-44 w-44 rounded-full bg-white/5"></div>
        <div
          class="absolute inset-0 opacity-[0.05]"
          style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 38px 38px;"
        ></div>

        <div class="relative flex flex-col gap-8 px-6 py-8 md:px-10 md:py-10 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-white/80">Newsletter</p>
            <h2 class="mt-3 text-3xl font-black leading-tight text-white">Want the next best angle before everyone else?</h2>
            <p class="mt-4 text-sm leading-7 text-white/80">
              Get new strategy notes, content ideas, and tool picks from the MoltyFlywheel editorial pipeline every week.
            </p>
          </div>

          <div class="w-full max-w-[320px]">
            <a
              href="/free-guide"
              class="inline-flex w-full items-center justify-center rounded-2xl bg-white px-5 py-3.5 text-sm font-bold text-[#0B3B59] transition-colors hover:bg-[#f0f8fc]"
            >
              Get the Free Guide →
            </a>
            <p class="mt-3 text-center text-xs text-white/70">Trusted by 2,400+ affiliate marketers</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById('blog-search');
  const clearButton = document.getElementById('blog-search-clear');
  const emptyStateClear = document.getElementById('empty-state-clear');
  const cards = document.querySelectorAll('.blog-card');
  const featuredCards = document.querySelectorAll('[data-featured-card]');
  const featuredSection = document.getElementById('featured-reads-section');
  const countEl = document.getElementById('results-count');
  const grid = document.getElementById('blog-grid');
  const emptyState = document.getElementById('empty-state');

  if (searchInput && cards.length && countEl && grid && emptyState) {
    const initialCountLabel = countEl.textContent || '';
    const applySearch = () => {
      const query = searchInput.value.trim().toLowerCase();
      let visible = 0;
      let visibleFeatured = 0;

      cards.forEach((card) => {
        const haystack = card.getAttribute('data-search') || '';

        const match = !query || haystack.includes(query);
        card.toggleAttribute('hidden', !match);

        if (match) {
          visible += 1;
        }
      });

      featuredCards.forEach((card) => {
        const haystack = card.getAttribute('data-search') || '';
        const match = !query || haystack.includes(query);
        card.toggleAttribute('hidden', !match);

        if (match) {
          visibleFeatured += 1;
        }
      });

      countEl.textContent = query
        ? `${visible} article${visible !== 1 ? 's' : ''} matching "${query}"`
        : initialCountLabel;

      grid.toggleAttribute('hidden', visible === 0);
      emptyState.classList.toggle('hidden', visible !== 0);
      emptyState.classList.toggle('flex', visible === 0);

      if (featuredSection) {
        featuredSection.toggleAttribute('hidden', query !== '' && visibleFeatured === 0);
      }

      if (clearButton) {
        clearButton.classList.toggle('hidden', query === '');
        clearButton.classList.toggle('flex', query !== '');
      }
    };

    const clearSearch = () => {
      searchInput.value = '';
      applySearch();
      searchInput.focus();
    };

    searchInput.addEventListener('input', applySearch);
    clearButton?.addEventListener('click', clearSearch);
    emptyStateClear?.addEventListener('click', clearSearch);
  }
</script>
