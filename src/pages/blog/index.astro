---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="Blog" description="AI affiliate marketing guides, reviews, and strategies from MoltyFlywheel.">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-black mb-4">Blog</h1>
    <p class="text-gray-400 mb-12">AI affiliate marketing guides, reviews, and case studies.</p>
    <div class="space-y-6">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="block bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-amber-500/50 transition-all group">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs text-amber-500 uppercase tracking-wider font-semibold bg-amber-500/10 px-2 py-1 rounded">{post.data.category}</span>
            <time class="text-xs text-gray-500">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          </div>
          <h2 class="text-xl font-bold mb-2 group-hover:text-amber-400 transition-colors">{post.data.title}</h2>
          <p class="text-gray-400">{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
