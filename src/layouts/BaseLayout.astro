---
import SEO from '../components/seo/SEO.astro';
import Header from '../components/nav/Header.astro';
import Footer from '../components/nav/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  robots?: string;
  structuredData?: unknown;
}

const { title, description, canonical, ogImage, ogType, robots, structuredData } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="ddeY6lw7wIYllf5jofjz9b0gNsEpUNehsFfW2jHXgxk" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <SEO
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    ogType={ogType}
    robots={robots}
    structuredData={structuredData}
  />
  <!-- Plausible Analytics (self-hosted) — outbound-links + tagged-events variant -->
  <!-- outbound-links: auto-tracks external link clicks as "Outbound Link: Click" -->
  <!-- tagged-events: enables plausible() JS calls for custom named events -->
  <script defer data-domain="moltyflywheel.com" src="https://plausible.moltyflywheel.com/js/script.outbound-links.tagged-events.js"></script>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-JDFSM4YMSC"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-JDFSM4YMSC');
  </script>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
